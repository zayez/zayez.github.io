---
import { getCollection, type CollectionEntry } from 'astro:content'
import PostLayout from '../../layouts/post-layout.astro'

interface Props {
  entry: CollectionEntry<'blog'>
  essayNumber: number
  totalEssays: number
}

export async function getStaticPaths() {
  const blogs = await getCollection('blog', (blog) => blog.data.draft !== true)
  const sorted = blogs.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  )
  return sorted.map((entry, i) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      essayNumber: sorted.length - i,
      totalEssays: sorted.length,
    },
  }))
}

const { entry, essayNumber, totalEssays } = Astro.props
const { Content, headings } = await entry.render()
---

<PostLayout
  entry={entry}
  headings={headings}
  essayNumber={essayNumber}
  totalEssays={totalEssays}
>
  <Content />
</PostLayout>
