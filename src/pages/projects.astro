---
import Main from '../layouts/main-layout.astro'
import Header from '@components/index/header.astro'
import MegaFooter from '@components/index/footer.astro'
import { getCollection } from 'astro:content'

const projects = await getCollection('projects')
const sorted = projects.sort((a, b) => {
  const ya = Number(a.data.year ?? 0)
  const yb = Number(b.data.year ?? 0)
  return yb - ya
})

const years = sorted
  .map((p) => Number(p.data.year ?? 0))
  .filter((y) => y > 0)
const yearRange =
  years.length > 0 ? `${Math.min(...years)} → ${Math.max(...years)}` : ''
---

<Main
  title="Zayez — Work"
  description="Selected projects — open-source and personal work by Enio E. Zanatta"
>
  <Header currentPage="projects" />

  <main>
    <header class="o3-blog-mast">
      <h1>W<span class="o">O</span>RK<span class="p">.</span></h1>
      <div class="o3-blog-sub">
        <span>
          / projects{yearRange ? ` · ${yearRange}` : ''} · open-source & personal
        </span>
        <span>Filter by status</span>
        <span class="count">
          Archive · <b>{String(sorted.length).padStart(2, '0')}</b>
        </span>
      </div>
    </header>

    <div class="o3-filter" data-filter-bar>
      <span class="label">§ Filter —</span>
      <button type="button" data-filter="all" class="is-on">all</button>
      <button type="button" data-filter="live">live</button>
      <button type="button" data-filter="wip">wip</button>
      <button type="button" data-filter="archived">archived</button>
      <span class="count" data-count>{sorted.length} showing</span>
    </div>

    <section class="o3-bloglist" data-project-list>
      {
        sorted.map((p, i) => {
          const status = p.data.status ?? 'live'
          const href = p.data.projectUrl || p.data.githubUrl || '#'
          return (
            <a
              href={href}
              target="_blank"
              rel="noreferrer"
              class="o3-blogitem"
              data-status={status}
            >
              <div class="n">{String(i + 1).padStart(2, '0')}</div>
              <div>
                <h3 class="o3-blog-t">{p.data.name}</h3>
                <p class="o3-blog-e">{p.data.long ?? p.data.description}</p>
                {p.data.stack && (
                  <div class="o3-stack">
                    {p.data.stack.map((s) => (
                      <span>{s}</span>
                    ))}
                  </div>
                )}
              </div>
              <div class="meta">
                <span class={`tag status-${status}`}>● {status}</span>
                <br />
                {p.data.role && (
                  <>
                    {p.data.role}
                    <br />
                  </>
                )}
                {p.data.year && (
                  <>
                    Year · {p.data.year}
                    <br />
                  </>
                )}
                {p.data.githubUrl && (
                  <span class="source">Source available</span>
                )}
              </div>
              <div class="arr">↗</div>
            </a>
          )
        })
      }
    </section>

    <script>
      const bar = document.querySelector<HTMLElement>('[data-filter-bar]')
      const list = document.querySelector<HTMLElement>('[data-project-list]')
      const countEl = document.querySelector<HTMLElement>('[data-count]')

      if (bar && list && countEl) {
        const items = Array.from(
          list.querySelectorAll<HTMLElement>('[data-status]')
        )
        const total = items.length

        bar.addEventListener('click', (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(
            '[data-filter]'
          )
          if (!btn) return
          const filter = btn.dataset.filter ?? 'all'

          bar
            .querySelectorAll<HTMLButtonElement>('[data-filter]')
            .forEach((b) => b.classList.toggle('is-on', b === btn))

          let shown = 0
          items.forEach((item) => {
            const match = filter === 'all' || item.dataset.status === filter
            item.style.display = match ? '' : 'none'
            if (match) shown++
          })
          countEl.textContent = `${shown} showing`
          if (filter === 'all') countEl.textContent = `${total} showing`
        })
      }
    </script>
  </main>

  <MegaFooter label="§ ready to build something" variant="projects" />
</Main>
