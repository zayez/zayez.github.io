---
interface Props {
  currentPage?: 'home' | 'blog' | 'post'
}

const { currentPage = 'home' } = Astro.props

const issueDate = new Date()
const issueMonth = issueDate.toLocaleString('en-US', { month: 'long' })
const issueYear = issueDate.getFullYear()
const issueNumber = 2
---

<nav class="o3-nav">
  <div class="o3-brand">
    <a href="/" aria-label="Home">zayez<span class="ast">.</span></a>
  </div>
  <div class="o3-nav-links">
    <a href="/" class={currentPage === 'home' ? 'is-on' : ''}>Home</a>
    <a
      href="/blog"
      class={currentPage === 'blog' || currentPage === 'post' ? 'is-on' : ''}
      >Blog</a
    >
    <a
      href="https://bsky.app/profile/zayez.bsky.social"
      target="_blank"
      rel="noreferrer">Contact</a
    >
  </div>
  <div class="o3-issue">
    Issue <b>№ {String(issueNumber).padStart(3, '0')}</b> / {issueMonth}
    {issueYear}
  </div>
</nav>
