---
import BaseHead from '@components/base-head.astro'
import '../styles/pages/zine.scss'

interface Props {
  title: string
  description?: string
}

const { title, description = '' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <div class="o3">
      <slot />
    </div>
  </body>
</html>
